# ───────────────────────────────────────────────────────────────
# Axano LeadFlow — Produktions-Umgebungsvariablen (Coolify)
# ───────────────────────────────────────────────────────────────
# Pflicht = muss gesetzt sein, sonst startet der Server nicht oder Features fallen aus
# Optional = kann leer bleiben; das betroffene Feature ist dann inaktiv

NODE_ENV=production

# ─── Basis ─────────────────────────────────────────────────────
# Pflicht. Internes Postgres-Passwort (Docker-Compose verwendet es).
DB_PASSWORT=HIER_SICHERES_PASSWORT_SETZEN

# Pflicht. JWT-Secrets (je mindestens 32 Zeichen, zufaellig generieren,
# z.B. `openssl rand -base64 48`). NIEMALS identisch, NIEMALS aus Doku kopieren.
JWT_GEHEIMNIS=HIER_ZUFAELLIGEN_STRING_SETZEN_MINDESTENS_32_ZEICHEN
REFRESH_TOKEN_GEHEIMNIS=HIER_ANDEREN_ZUFAELLIGEN_STRING_SETZEN
# Optional. Standard 8h / 30d.
# JWT_ABLAUF=8h
# REFRESH_TOKEN_ABLAUF=30d

# Pflicht. Schluessel fuer API-Key-Verschluesselung in der DB (AES-256-GCM).
# Exakt 32 Hex-Zeichen. Bei Rotation werden bestehende Integrationen unlesbar!
VERSCHLUESSELUNGS_SCHLUESSEL=HIER_32_HEX_ZEICHEN_SETZEN

# Pflicht. Oeffentliche URLs.
API_BASE_URL=https://leadflow.axano.com
FRONTEND_URL=https://leadflow.axano.com

# ─── KI (Anthropic) ────────────────────────────────────────────
# Pflicht fuer Kampagnen-Generierung und Transkript-Analyse.
# Ohne diesen Key: keine automatische Lead-Klassifizierung nach Anrufen.
ANTHROPIC_API_KEY=sk-ant-api03-DEIN_KEY_HIER

# ─── Facebook Lead Ads ─────────────────────────────────────────
# Pflicht wenn Kunden Facebook anbinden wollen.
FACEBOOK_APP_ID=
FACEBOOK_APP_GEHEIMNIS=
# Beliebiger selbstgesetzter String, wird im Meta-App-Dashboard als Verify-Token eingetragen.
FACEBOOK_VERIFY_TOKEN=

# ─── WhatsApp Business (Meta) ──────────────────────────────────
# Pflicht wenn Kunden WhatsApp Business ueber Meta verwenden wollen.
# Wenn nur Superchat genutzt wird, kann dieser Block leer bleiben.
WHATSAPP_VERIFY_TOKEN=

# ─── Google Calendar OAuth ─────────────────────────────────────
# Optional. Ohne: Kunden koennen Google Calendar nicht verbinden.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_GEHEIMNIS=

# ─── Outlook Calendar OAuth ────────────────────────────────────
# Optional. Ohne: Kunden koennen Outlook Calendar nicht verbinden.
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_GEHEIMNIS=
OUTLOOK_TENANT_ID=common

# ─── VAPI (AI-Anrufe) ──────────────────────────────────────────
# Optional. Das Geheimnis validiert eingehende VAPI-Webhooks.
# Kann auch pro Kunde in der Integrations-UI gesetzt werden.
VAPI_WEBHOOK_SECRET=

# ─── SMTP (E-Mail-Versand) ─────────────────────────────────────
# Optional. Ohne SMTP: Follow-up-Mails an Leads werfen in Produktion einen
# Fehler (kein stiller Datenverlust). Einladungs-Mails fuer Kunden-Zugaenge
# sind aktuell nicht in Benutzung (Admin legt Passwort direkt an).
# Provider-Empfehlung fuer transaktionale Mails: Postmark oder AWS SES.
SMTP_HOST=
SMTP_PORT=587
SMTP_BENUTZER=
SMTP_PASSWORT=
SMTP_ABSENDER_NAME=Axano LeadFlow

# ─── Monitoring (Sentry) ───────────────────────────────────────
# Stark empfohlen. Ohne DSN laeuft Sentry still und Fehler sind nur in Logs sichtbar.
# DSN aus sentry.io → Project Settings → Client Keys kopieren.
SENTRY_DSN=
# Optional. Wird als Release-Tag in Sentry angezeigt (z.B. git-SHA).
SENTRY_RELEASE=

# ─── Admin-Adressen ────────────────────────────────────────────
# Optional. Empfaenger fuer interne System-Benachrichtigungen.
ADMIN_EMAIL=admin@axano.com
