# ── Axano LeadFlow – Produktions-Umgebungsvariablen ──

# Datenbank
DB_PASSWORT=HIER_SICHERES_PASSWORT_SETZEN

# JWT Auth (mindestens 32 Zeichen, zufällig generieren)
JWT_GEHEIMNIS=HIER_ZUFAELLIGEN_STRING_SETZEN_MINDESTENS_32_ZEICHEN
REFRESH_TOKEN_GEHEIMNIS=HIER_ANDEREN_ZUFAELLIGEN_STRING_SETZEN

# Verschlüsselung für API-Keys (32 Zeichen hex)
VERSCHLUESSELUNGS_SCHLUESSEL=HIER_32_HEX_ZEICHEN_SETZEN

# URLs (Domain anpassen!)
API_BASE_URL=https://leadflow.axano.com
FRONTEND_URL=https://leadflow.axano.com

# Anthropic (Claude) – für KI-Generierung und Transkript-Analyse
ANTHROPIC_API_KEY=sk-ant-api03-DEIN_KEY_HIER

# Google Calendar OAuth (optional, für Kunden-Kalender)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_GEHEIMNIS=

# Outlook Calendar OAuth (optional, für Kunden-Kalender)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_GEHEIMNIS=
OUTLOOK_TENANT_ID=common
